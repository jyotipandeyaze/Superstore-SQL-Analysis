<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="superstore.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2467"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Orders" custom_title="0" dock_id="1" table="4,6:mainOrders"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Orders" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="50"/><column index="2" value="117"/><column index="3" value="85"/><column index="4" value="85"/><column index="5" value="117"/><column index="6" value="78"/><column index="7" value="163"/><column index="8" value="93"/><column index="9" value="109"/><column index="10" value="132"/><column index="11" value="117"/><column index="12" value="73"/><column index="13" value="62"/><column index="14" value="124"/><column index="15" value="124"/><column index="16" value="93"/><column index="17" value="300"/><column index="18" value="78"/><column index="19" value="56"/><column index="20" value="57"/><column index="21" value="85"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="Query 1 — Sales by Region*">SELECT Region,
       SUM(Sales) AS Total_Sales
FROM Orders
GROUP BY Region;</sql><sql name="Query 2 — Profit by Category*">SELECT Category,
       SUM(Profit) AS Total_Profit
FROM Orders
GROUP BY Category;</sql><sql name="Query 3 — Orders by Ship Mode*">SELECT &quot;Ship Mode&quot;,
       COUNT(*) AS Total_Orders
FROM Orders
GROUP BY &quot;Ship Mode&quot;;</sql><sql name="Query 4 — Regions with Sales &gt; 100000*">SELECT Region,
       SUM(Sales) AS Revenue
FROM Orders
GROUP BY Region
HAVING Revenue &gt; 100000;</sql><sql name="Query 5 — Categories with Profit &gt; 50000*">SELECT Category,
       SUM(Profit) AS Profit
FROM Orders
GROUP BY Category
HAVING Profit &gt; 50000;</sql><sql name="Query 6 — Average Sales*">SELECT AVG(Sales) AS Average_Sales
FROM Orders;</sql><sql name="Query 7 — Unique Categories*">SELECT DISTINCT Category
FROM Orders;</sql><sql name="Product table*">CREATE TABLE Products AS
SELECT DISTINCT &quot;Product ID&quot;,
       &quot;Product Name&quot;,
       Category,
       &quot;Sub-Category&quot;
FROM Orders</sql><sql name="INNER JOIN*">SELECT o.&quot;Order ID&quot;,
       o.Sales,
       p.&quot;Product Name&quot;,
       p.Category
FROM Orders o
INNER JOIN Products p
ON o.&quot;Product ID&quot; = p.&quot;Product ID&quot;
LIMIT 10;</sql><sql name="Left JOIN*">SELECT o.&quot;Order ID&quot;,
       o.&quot;Customer Name&quot;,
       p.Category
FROM Orders o
LEFT JOIN Products p
ON o.&quot;Product ID&quot; = p.&quot;Product ID&quot;
LIMIT 10;</sql><sql name="SUBQUERY&#10;✅ Above Average Sales Orders*">SELECT &quot;Product Name&quot;,
       Sales
FROM Orders
WHERE Sales &gt;
(
    SELECT AVG(Sales)
    FROM Orders
);</sql><sql name="CASE WHEN&#10;✅ Sales Segmentation*">SELECT &quot;Product Name&quot;,
       Sales,
       CASE
           WHEN Sales &gt; 500 THEN 'High Sales'
           ELSE 'Low Sales'
       END AS Sales_Category
FROM Orders
LIMIT 20;</sql><sql name="TOP 10 PRODUCTS*">SELECT &quot;Product Name&quot;,
       SUM(Sales) AS Total_Sales
FROM Orders
GROUP BY &quot;Product Name&quot;
ORDER BY Total_Sales DESC
LIMIT 10;</sql><sql name="TOP CUSTOMERS*">SELECT &quot;Customer Name&quot;,
       SUM(Sales) AS Revenue
FROM Orders
GROUP BY &quot;Customer Name&quot;
ORDER BY Revenue DESC
LIMIT 10;</sql><sql name="LOSS MAKING PRODUCTS*">SELECT &quot;Product Name&quot;,
       SUM(Profit) AS Total_Profit
FROM Orders
GROUP BY &quot;Product Name&quot;
HAVING Total_Profit &lt; 0
ORDER BY Total_Profit;</sql><sql name="MONTHLY SALES TREND*">SELECT strftime('%Y-%m', &quot;Order Date&quot;) AS Month,
       SUM(Sales) AS Revenue
FROM Orders
GROUP BY Month
ORDER BY Month;</sql><current_tab id="15"/></tab_sql></sqlb_project>
